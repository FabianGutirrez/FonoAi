rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow connection test
    match /test/connection {
      allow get: if true;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
               data.email is string && data.email.size() > 0 && data.email.size() <= 100 &&
               data.uid == request.auth.uid;
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['name']) &&
                    incoming().createdAt == existing().createdAt;
    }

    // 2. Patients Collection
    match /patients/{patientId} {
      function isValidPatient(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
               data.createdBy == request.auth.uid;
      }

      allow read: if isSignedIn() && resource.data.createdBy == request.auth.uid;
      allow create: if isSignedIn() && isValidPatient(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && existing().createdBy == request.auth.uid && 
                    isValidPatient(incoming()) &&
                    incoming().createdBy == existing().createdBy &&
                    incoming().createdAt == existing().createdAt;
      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;
    }

    // 3. Evaluations Collection
    match /evaluations/{evaluationId} {
      function isValidEvaluation(data) {
        return data.patientId is string && isValidId(data.patientId) &&
               data.status in ['pendiente', 'procesando', 'completada', 'revisión necesaria'] &&
               data.createdBy == request.auth.uid;
      }

      allow read: if isSignedIn() && resource.data.createdBy == request.auth.uid;
      allow create: if isSignedIn() && isValidEvaluation(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && existing().createdBy == request.auth.uid && 
                    isValidEvaluation(incoming()) &&
                    incoming().createdBy == existing().createdBy &&
                    incoming().createdAt == existing().createdAt &&
                    (
                      // Action: Status Update (from AI processing)
                      (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'transcription', 'analysis', 'updatedAt'])) ||
                      // Action: General edit
                      (incoming().diff(existing()).affectedKeys().hasOnly(['patientId', 'videoName', 'updatedAt']))
                    );
      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;
    }
  }
}
